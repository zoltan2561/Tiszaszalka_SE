Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^tiszaszalkase\.com$ [NC]
  RewriteRule ^ https://tiszaszalkase.com%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_authz_core.c>
  Require all granted
</IfModule>
